# Задание: структура данных "Участники спора"
# Список словарей, каждый словарь — участник с ключами: name, status, inn

# Создаём пустой список для участников
participants = []

# Запрашиваем данные для трёх участников
for i in range(1, 4):
    print(f"\n--- Участник {i} ---")
    name = input("Введите наименование участника: ")
    status = input("Введите статус (Истец/Ответчик/Третье лицо): ")
    inn = input("Введите ИНН: ")

    # Добавляем словарь с данными в список
    participants.append({
        "name": name,
        "status": status,
        "inn": inn
    })

# Выводим полученную структуру в консоль
print("\n--- Итоговая структура данных ---")
print(participants)
