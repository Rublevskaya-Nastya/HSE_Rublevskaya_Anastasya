# Пример работы id() для изменяемых и неизменяемых объектов
a = [1, 2, 3]
b = "строка"
print("id списка до изменения:", id(a))
a.append(4)
print("id списка после изменения:", id(a))  # id не изменился

print("id строки:", id(b))
# b += "!" — если раскомментировать, id изменится, т.к. строки неизменяемы

# Задание 2. Перевод секунд в часы, минуты, секунды
time_str = input("Введите время в секундах: ")

if time_str.isdigit():
    total_seconds = int(time_str)
    hours = total_seconds // 3600
    minutes = (total_seconds % 3600) // 60
    seconds = total_seconds % 60
    print(f"Часы: {hours}")
    print(f"Минуты: {minutes}")
    print(f"Секунды: {seconds}")
else:
    print("Ошибка: введите только числовые данные!")

# Задание 3. Сумма n + nn + nnn
n_str = input("Введите число n (от 1 до 9): ")

if n_str.isdigit() and 1 <= int(n_str) <= 9:
    n = int(n_str)
    nn = int(n_str * 2)
    nnn = int(n_str * 3)
    result = n + nn + nnn
    print(f"Сумма {n} + {nn} + {nnn} = {result}")
else:
    print("Ошибка: введите целое число от 1 до 9!")
